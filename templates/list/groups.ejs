<div class="table-container">
  <table class="table is-bordered">
    <thead>
      <tr>
        <th>id</th>
        <th>user</th>
        <th>role</th>
      </tr>
    </thead>
    <tbody>
      <% for (let i = 0; i < rows.length; i++) {%>
        <tr>
          <td><%= rows[i].id %></td>
          <td><%= rows[i].user_name %></td>
          <td><%= rows[i].role_name %></td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>
